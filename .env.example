# MongoDB Connection
# Replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio

# Admin Dashboard Login
# Seed an admin user in the DB (bcrypt-hashed) via `node scripts/seed-admin.mjs --email you@example.com --password "..."`
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Spotify OAuth (For Currently Playing)
# Follow instructions on Spotify Developer Dashboard to get these
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# GitHub Stats
# Generate a Personal Access Token (classic) with no scopes/basic scopes in GitHub Developer Settings
GITHUB_USERNAME=ishivamgaur
GITHUB_TOKEN=your_github_personal_access_token_here

# Cloudinary Cred
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# Umami Analytics
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id_here
